# ── Railway injects PORT automatically. Do NOT set PORT in production. ──
PORT=8080

# ── Supabase (Singapore region) · Project Settings → API ──
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# service_role key (server-only, NEVER expose to the browser)
SUPABASE_SERVICE_KEY=your-service-role-key

# ── OpenRouter · https://openrouter.ai/keys ──
OPENROUTER_API_KEY=sk-or-...
# set to the current Haiku 4.5 slug on OpenRouter
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# ── CORS · include BOTH www and non-www, comma-separated ──
ALLOWED_ORIGINS=https://clawtifact.xyz,https://www.clawtifact.xyz,http://localhost:5500,http://127.0.0.1:5500

# ── Abuse controls ──
# max /transmit calls per IP per day
DAILY_QUOTA=50
# long random string — IPs are hashed with this, never stored raw
IP_SALT=change-me-to-a-long-random-string
